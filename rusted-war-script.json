      }
    },
    {
      "sceneKey": "mecha_flank",
      "content": {
        "bg": "https://images.unsplash.com/photo-1517649763962-0c623066050b?w=1920",
        "text": "基础机甲：'收到！执行侧翼机动！'\n基础机甲快速移动到敌方侧翼，发起突袭！\n基础机甲：'发现敌方弱点！正在攻击！'",
        "characters": [
          {
            "name": "基础机甲",
            "image": "/uploads/images/scenes/characters/47982733-a03a-473a-8628-dcfec368a1a6.png",
