    },
    {
      "sceneKey": "offensive_strategy",
      "content": {
        "bg": "https://images.unsplash.com/photo-1474302770737-173ee21bab63?w=1920",
        "text": "指挥官决定主动出击！\n武装直升机：'明白！我将带领机动部队突袭敌方能源设施！'\n等离子坦克：'我请求加入突击队，我的等离子武器对付建筑非常有效！'",
        "characters": [
          {
            "name": "武装直升机",
            "image": "/uploads/images/scenes/characters/700aafa8-4e2a-4240-bc2d-d31c1d8e25ec.png",
            "position": "left"
          },
          {
            "name": "等离子坦克",
            "image": "/uploads/images/scenes/characters/02af157b-0dee-4205-81db-36f99dfab350.png",
            "position": "right"
          }
        ],
        "options": [
          {
            "text": "批准！突击队出发！",
            "next": "assault_mission"
          },
          {
            "text": "等等，还是先防守吧",
            "next": "defensive_strategy"
          }
