target/

# IDE 配置
.idea/
*.iml

# 日志文件
logs/
*.log

# 环境变量文件
.env

# 上传文件目录（保留.gitkeep）
uploads/images/**/*.jpg
uploads/images/**/*.jpeg
uploads/images/**/*.png
